DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/factory_hypotheses
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=~openai/gpt-latest
OPENROUTER_APP_TITLE=Factory of Hypotheses MVP
OPENROUTER_APP_URL=http://localhost:8000

# RAG через Yandex Cloud Foundation Models (YandexGPT + text embeddings)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_CHAT_MODEL=yandexgpt-lite
YANDEX_EMBED_DOC_MODEL=text-search-doc
YANDEX_EMBED_QUERY_MODEL=text-search-query
YANDEX_TIMEOUT=60
EMBED_DIM=256
CORPUS_PATH=Задача 1
RAG_TOP_K=6

# --- Развёртывание на сервере (используются docker-compose) ---
# Учётные данные Postgres. На сервере обязательно смени пароль на свой.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=factory_hypotheses
# Публичный порт UI на сервере (прод-оверлей). 80 — обычный HTTP.
APP_PORT=80
# Число uvicorn-воркеров API в проде.
API_WORKERS=2
